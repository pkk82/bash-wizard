# claude - run claude with CLAUDE_CONFIG_DIR set to nearest .claude dir up the hierarchy (fallback: $HOME/.claude)
function claude() {
  local dir="$PWD"
  local configDir=""
  while [[ "$dir" != "/" ]]; do
    if [[ -d "$dir/.claude" ]]; then
      configDir="$dir/.claude"
      break
    fi
    dir="$(dirname "$dir")"
  done
  [[ -z "$configDir" ]] && configDir="$HOME/.claude"
  printf "\e[1;36mCLAUDE_CONFIG_DIR=%s\e[0m\n" "$configDir"
  CLAUDE_CONFIG_DIR="$configDir" command claude "$@"
}