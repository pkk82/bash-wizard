# openssl-generate-certificate <name> <subject> <passphrase>
function openssl-generate-certificate() {
  local name="$1"
  local subject="$2"
  local passphrase="$3"
  local passphraseDir;
  local passphraseFilePath
  if [[ "$passphrase" == "" ]]; then
    echo "Use: openssl-generate-certificate <name> <subject> <passphrase>"
    echo "  <name> - name of the certificate used for filenames"
    echo "  <subject> - subject of the certificate"
    echo "    example: /C=<country>/ST=<state>/L=<location>/O=<organization>/OU=<organization unit>/CN=<common name>"
    echo "  <passphrase> - passphrase for the private key"
    return 1
  fi

  passphraseDir="$TMPDIR/$(date +%s)"
  passphraseFilePath="$passphraseDir/$(date +%s)"
  mkdir -m 700 "$passphraseDir"
  echo "$passphrase" > "$passphraseFilePath"
  chmod 600 "$passphraseFilePath"

  echo "Generating private key to ${name}.key"
  openssl genrsa \
    -aes256 \
    -passout file:"$passphraseFilePath" \
    -out "./${name}.key" 4096

  echo "Generating certificate to ${name}.crt"
  openssl req \
    -new \
    -sha256 \
    -x509 \
    -days 365 \
    -key "./${name}.key" \
    -subj "$subject" \
    -out "./${name}.crt" \
    -passin file:"$passphraseFilePath"
  rm -rf "$passphraseDir"
}

# openssl-generate-server-certificate-signed-by-ca <ca-cert> <ca-key> <name> <subject> <alt-names>
function openssl-generate-server-certificate-signed-by-ca() {
  local ca_crt="$1"
  local ca_key="$2"
  local name="$3"
  local subject="$4"
  local alt_names="$5"

  if [[ "$subject" == "" ]]; then
    echo "Use: openssl-generate-server-certificate-signed-by-ca <ca-cert> <ca-key> <name> <subject> <alt-names>"
    echo "  <ca-cert> - path to CA certificate"
    echo "  <ca-key> - path to CA key"
    echo "  <name> - name used for output filenames (e.g. server -> server.key, server.csr, server.crt)"
    echo "  <subject> - subject of the certificate"
    echo "    example: /C=<country>/ST=<state>/L=<location>/O=<organization>/OU=<organization unit>/CN=<common name>"
    echo " <alt-names> - alternative names for the certificate "
    echo "    example: DNS:example.com,DNS:www.example.com,IP:127.0.0.1"
    return 1
  fi

  echo "Generating server key to ./${name}.key file"
  openssl genrsa -out "${name}.key" 4096

  echo "Generating certificate signing request to ./${name}.csr file"
  openssl req \
    -subj "$subject" \
    -sha256 \
    -new \
    -key "${name}.key" \
    -out "${name}.csr"

  echo "Generating ./${name}.cnf file"
  echo extendedKeyUsage = serverAuth > "${name}.cnf"
  if [[ "$alt_names" != "" ]]; then
    echo subjectAltName = "$alt_names" >> "${name}.cnf"
  fi

  echo "Generating certificate to ./${name}.crt file"
  openssl x509 \
    -req \
    -days 365 \
    -sha256 \
    -in "${name}.csr" \
    -CA "$ca_crt" \
    -CAkey "$ca_key" \
    -CAcreateserial \
    -extfile "${name}.cnf" \
    -out "${name}.crt"

  rm -f "${name}.csr" "${name}.cnf"
}

# openssl-display-certificate <certificate>
function openssl-display-certificate() {
  local cert="$1"
  openssl x509 -in "$cert" -text -noout
}
